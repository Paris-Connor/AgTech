<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Educational Drum Machine</title>
    <style>
        :root {
            --bg: #1a1a2e;
            --panel: #16213e;
            --accent: #48cae4;
            --kick: #ff4d6d;
            --snare: #ffb703;
            --hihat: #8338ec;
            --text: #edf2f4;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: var(--bg);
            color: var(--text);
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 20px;
            margin: 0;
        }

        h1 { margin-bottom: 10px; color: var(--accent); }

        .container {
            background: var(--panel);
            padding: 25px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            max-width: 800px;
            width: 100%;
        }

        .controls {
            display: flex;
            gap: 20px;
            margin-bottom: 20px;
            align-items: center;
            background: rgba(255,255,255,0.05);
            padding: 15px;
            border-radius: 8px;
        }

        .sequencer {
            display: grid;
            grid-template-columns: 100px repeat(16, 1fr);
            gap: 5px;
            margin-bottom: 20px;
        }

        .label {
            font-weight: bold;
            display: flex;
            align-items: center;
            cursor: help;
        }

        .step {
            aspect-ratio: 1/1;
            background: #2b2d42;
            border: 1px solid #3d405b;
            border-radius: 4px;
            cursor: pointer;
            transition: 0.2s;
        }

        .step.active-kick { background: var(--kick); box-shadow: 0 0 10px var(--kick); }
        .step.active-snare { background: var(--snare); box-shadow: 0 0 10px var(--snare); }
        .step.active-hihat { background: var(--hihat); box-shadow: 0 0 10px var(--hihat); }
        
        .step.current-step {
            border: 2px solid white;
            transform: scale(1.1);
        }

        .education-panel {
            background: #0f172a;
            padding: 15px;
            border-left: 4px solid var(--accent);
            border-radius: 4px;
            min-height: 80px;
        }

        button {
            padding: 10px 20px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            border: none;
            border-radius: 5px;
            background: var(--accent);
            color: #000;
        }

        button:hover { opacity: 0.9; }

        input[type="range"] { cursor: pointer; }
    </style>
</head>
<body>

    <h1>BeatMaker Academy</h1>

    <div class="container">
        <div class="controls">
            <button id="playBtn">▶ Play</button>
            <div>
                <label>BPM: <span id="bpmVal">120</span></label><br>
                <input type="range" id="bpm" min="60" max="180" value="120">
            </div>
            <p><i>Click a step to toggle sound. Hover labels to learn!</i></p>
        </div>

        <div class="sequencer" id="sequencer">
            </div>

        <div class="education-panel" id="eduText">
            <strong>Welcome!</strong> Press Play to start the timeline. Click the square boxes to add notes. Try placing a "Kick" on steps 1, 5, 9, and 13 for a "Four on the Floor" beat.
        </div>
    </div>

    <script>
        const audioCtx = new (window.AudioContext || window.webkitAudioContext)();
        const sequencer = document.getElementById('sequencer');
        const eduText = document.getElementById('eduText');
        const bpmInput = document.getElementById('bpm');
        const bpmVal = document.getElementById('bpmVal');
        const playBtn = document.getElementById('playBtn');

        let isPlaying = false;
        let currentStep = 0;
        let nextStepTime = 0;
        const lookahead = 25.0; 
        const scheduleAheadTime = 0.1;

        const instruments = [
            { name: 'Kick', color: 'active-kick', freq: 60, info: "The Kick (Bass Drum) provides the 'pulse'. In most dance music, it hits on steps 1, 5, 9, and 13." },
            { name: 'Snare', color: 'active-snare', freq: 200, info: "The Snare adds 'backbeat' energy. It usually hits on steps 5 and 13 to create a sense of resolution." },
            { name: 'Hi-Hat', color: 'active-hihat', freq: 1000, info: "Hi-Hats provide the 'subdivision' or groove. Faster patterns make a beat feel more urgent." }
        ];

        // Build UI
        instruments.forEach((inst, rowIndex) => {
            const label = document.createElement('div');
            label.className = 'label';
            label.innerText = inst.name;
            label.onmouseover = () => eduText.innerHTML = `<strong>${inst.name}:</strong> ${inst.info}`;
            sequencer.appendChild(label);

            for (let i = 0; i < 16; i++) {
                const step = document.createElement('div');
                step.className = 'step';
                step.dataset.row = rowIndex;
                step.dataset.step = i;
                if (i % 4 === 0) step.style.background = '#343a40'; // Visual grouping
                step.onclick = () => step.classList.toggle(inst.color);
                sequencer.appendChild(step);
            }
        });

        function playSound(freq, type) {
            const osc = audioCtx.createOscillator();
            const gain = audioCtx.createGain();
            
            osc.type = type === 'Hi-Hat' ? 'triangle' : 'sine';
            osc.frequency.setValueAtTime(freq, audioCtx.currentTime);
            
            if (type === 'Kick') {
                osc.frequency.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.5);
            }

            gain.gain.setValueAtTime(0.3, audioCtx.currentTime);
            gain.gain.exponentialRampToValueAtTime(0.01, audioCtx.currentTime + 0.2);

            osc.connect(gain);
            gain.connect(audioCtx.destination);
            osc.start();
            osc.stop(audioCtx.currentTime + 0.2);
        }

        function nextTick() {
            const secondsPerBeat = 60.0 / bpmInput.value / 4; 
            nextStepTime += secondsPerBeat;
            currentStep = (currentStep + 1) % 16;
        }

        function scheduleNote(stepNumber, time) {
            const steps = document.querySelectorAll(`[data-step="${stepNumber}"]`);
            
            // Visual playhead
            document.querySelectorAll('.step').forEach(s => s.classList.remove('current-step'));
            steps.forEach(step => {
                step.classList.add('current-step');
                
                // Play logic
                if (step.classList.contains('active-kick')) playSound(60, 'Kick');
                if (step.classList.contains('active-snare')) playSound(200, 'Snare');
                if (step.classList.contains('active-hihat')) playSound(800, 'Hi-Hat');
            });
        }

        function scheduler() {
            while (nextStepTime < audioCtx.currentTime + scheduleAheadTime) {
                scheduleNote(currentStep, nextStepTime);
                nextTick();
            }
            if (isPlaying) setTimeout(scheduler, lookahead);
        }

        playBtn.onclick = () => {
            if (audioCtx.state === 'suspended') audioCtx.resume();
            isPlaying = !isPlaying;
            if (isPlaying) {
                playBtn.innerText = 'Stop';
                currentStep = 0;
                nextStepTime = audioCtx.currentTime;
                scheduler();
            } else {
                playBtn.innerText = '▶ Play';
            }
        };

        bpmInput.oninput = () => bpmVal.innerText = bpmInput.value;
    </script>
</body>
</html>
